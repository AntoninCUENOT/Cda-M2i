# ==============================
# Frontend (Expo)
# ==============================
EXPO_PUBLIC_API_URL=http://localhost:3000/api
EXPO_PUBLIC_JIKAN_URL=https://api.jikan.moe/v4

# ==============================
# PostgreSQL
# ==============================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=animetracker
POSTGRES_USER=animetracker_user
