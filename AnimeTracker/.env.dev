# ==============================
# Redis
# ==============================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==============================
# Backend Node.js
# ==============================
NODE_ENV=development
PORT=3000
JWT_SECRET=change_this_secret_in_production_min_32_chars
JWT_EXPIRES_IN=7d
JIKAN_API_URL=https://api.jikan.moe/v4
